# === Klucz Anthropic API ===
# Wymagany. Pobierz z https://console.anthropic.com
VITE_ANTHROPIC_API_KEY=sk-ant-api03-...twoj-klucz-tutaj...

# === Supabase (opcjonalne) ===
# Jeśli ustawione -> dane lecą do chmury, wymagane logowanie
# Jeśli puste     -> dane w localStorage przeglądarki
# Pobierz z https://supabase.com -> Project Settings -> API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# UWAGA: .env jest w .gitignore — NIE commituj kluczy do repo
